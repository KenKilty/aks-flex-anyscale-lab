# Environment configuration for the AKS Flex Node + Anyscale sample.
#
# Usage:  cp .env-template .env  then fill in real values in .env (never commit .env).
# .env and .env-template share the same keys and ordering; only values differ.
#
#   ARM_*    controls Azure authentication.
#   TF_VAR_* is written to infra/terraform/terraform.auto.tfvars.json during deploy.
#
# To run an alternate profile without editing .env, point at another file
# formatted like this one:  ANYSCALE_AKS_ENV_FILE=<file> ./scripts/anyscale-aks.sh <command>

###############################################################################
# Azure operator context
###############################################################################
ARM_SUBSCRIPTION_ID="00000000-0000-0000-0000-000000000000"
ARM_TENANT_ID="00000000-0000-0000-0000-000000000000"
ARM_USE_CLI="true"

TF_VAR_azure_subscription_id="00000000-0000-0000-0000-000000000000"
TF_VAR_azure_tenant_id="00000000-0000-0000-0000-000000000000"

###############################################################################
# Deployment naming and locations
###############################################################################
TF_VAR_project="flexany"
TF_VAR_environment="dev"
# Intended home region for the deployment. To bring up in a different region
# (for example on capacity constraints), change both TF_VAR_azure_location and
# TF_VAR_region_short together.
TF_VAR_azure_location="westus3"
TF_VAR_region_short="wus3"
TF_VAR_flex_region="westus2"
TF_VAR_flex_region_short="wus2"
TF_VAR_tags='{"Project":"flexany","Environment":"dev","ManagedBy":"terraform","Owner":"change-me"}'
SSH_PRIVATE_KEY_PATH="${HOME:-/home/${USER:-azureoperator}}/.ssh/id_ed25519"

###############################################################################
# Core networking
###############################################################################
TF_VAR_vnet_address_space='["10.50.0.0/16"]'
TF_VAR_subnet_cidrs='{"firewall":"10.50.0.0/26","bastion":"10.50.0.128/26","aks_apiserver":"10.50.1.0/28","dns_resolver_in":"10.50.1.16/28","dns_resolver_out":"10.50.1.32/28","private_endpoints":"10.50.2.0/24","aks_nodes":"10.50.4.0/22"}'
TF_VAR_flex_vnet_address_space='["10.60.0.0/16"]'
TF_VAR_flex_subnet_cidr="10.60.1.0/24"
TF_VAR_service_cidr="10.100.0.0/16"
TF_VAR_dns_service_ip="10.100.0.10"
TF_VAR_dns_forwarding_rules='{}'

###############################################################################
# AKS sizing
###############################################################################
TF_VAR_availability_zones='["1","2","3"]'
TF_VAR_aks_sku_tier="Standard"
TF_VAR_kubernetes_version='"1.34.6"'
TF_VAR_system_node_pool_min_count="1"
TF_VAR_system_node_pool_max_count="3"
TF_VAR_system_vm_size="Standard_D4s_v5"
TF_VAR_cpu_vm_size="Standard_D16s_v5"
TF_VAR_gpu_pool_configs='{"T4":{"name":"gput4","vm_size":"Standard_NC16as_T4_v3","product_name":"NVIDIA-T4","gpu_count":"1","min_count":1,"max_count":2,"availability_zones":[]}}'

###############################################################################
# Optional Flex host provisioning for join/bootstrap phase
###############################################################################
TF_VAR_flex_host_enabled="false"
TF_VAR_flex_host_vm_size="Standard_NC16as_T4_v3"
TF_VAR_flex_host_admin_username="azureoperator"
# Leave blank to auto-load from ${SSH_PRIVATE_KEY_PATH}.pub when enabled.
TF_VAR_flex_host_admin_ssh_public_key=""
TF_VAR_flex_host_public_ip_enabled="true"
TF_VAR_flex_host_os_disk_size_gb="256"
TF_VAR_flex_host_source_image_reference='{"publisher":"microsoft-dsvm","offer":"ubuntu-hpc","sku":"2204","version":"latest"}'
AKS_FLEX_AGENT_POOL_NAME="aksflexnodes"

###############################################################################
# Anyscale operator identity foundation
###############################################################################
TF_VAR_anyscale_operator_namespace="anyscale-operator"
TF_VAR_anyscale_operator_serviceaccount="anyscale-operator"
TF_VAR_anyscale_operator_identity='{"mode":"create"}'

###############################################################################
# Storage, registry, observability
###############################################################################
TF_VAR_storage_cors_rule='{"allowed_headers":["*"],"allowed_methods":["GET","POST","PUT","HEAD","DELETE"],"allowed_origins":["https://*.anyscale.com"],"expose_headers":["Accept-Ranges","Content-Range","Content-Length"],"max_age_in_seconds":0}'
TF_VAR_storage_replication_type="ZRS"
TF_VAR_acr_zone_redundancy_enabled="true"
TF_VAR_log_analytics_retention_days="30"
TF_VAR_log_analytics_internet_ingestion_enabled="false"
TF_VAR_log_analytics_internet_query_enabled="true"
TF_VAR_ampls_enabled="true"
TF_VAR_ampls_ingestion_access_mode="PrivateOnly"
TF_VAR_ampls_query_access_mode="Open"
TF_VAR_container_insights_v2_enabled="true"
TF_VAR_container_insights_streams='["Microsoft-ContainerLogV2","Microsoft-KubeEvents","Microsoft-KubePodInventory"]'
TF_VAR_container_insights_data_collection_interval="1m"
TF_VAR_container_insights_namespace_filtering_mode="Off"
TF_VAR_container_insights_namespaces='[]'
TF_VAR_terraform_managed_diagnostic_settings_enabled="true"

###############################################################################
# AKS RBAC
###############################################################################
TF_VAR_assign_current_principal_cluster_access="true"
TF_VAR_aks_cluster_admin_principal_ids='{}'
TF_VAR_aks_cluster_user_principal_ids='{}'
